# ============================================================
# VARIÁVEIS DE AMBIENTE — copiar para .env e preencher valores
# NUNCA commitar o ficheiro .env
# ============================================================

# --- Login no site Codisys ---
CODISYS_EMAIL=
senha=

# --- Azure App Registration (Microsoft Graph API) ---
# Obtidos no portal Azure > App registrations > <app> > Overview / Certificates & secrets
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# --- Caixa de correio que envia os emails (deve existir no tenant Azure) ---
MAIL_SENDER=

# --- Caminho do Chrome (apenas necessário no Linux/servidor) ---
# Em Windows o caminho é lido do config.json (campo chrome.caminho)
# No Linux, se não definido, o script tenta auto-detectar google-chrome / chromium
# Exemplo Ubuntu: CHROME_PATH=/usr/bin/google-chrome
CHROME_PATH=
